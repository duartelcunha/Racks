<Window x:Class="Racks.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Racks"
        mc:Ignorable="d"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="White"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        ResizeMode="NoResize"
        Title="About Racks"
        SizeToContent="Height"
        MinHeight="0" MinWidth="0"
        Width="270"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="14" BorderThickness="1" Margin="20"
            Background="{StaticResource RacksCardBackground}"
            BorderBrush="{StaticResource RacksCardBorder}"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="0.92" ScaleY="0.92"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="15" Opacity="0.5"/>
        </Border.Effect>

        <Grid Margin="20,14,20,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Close button, top-right -->
            <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Style="{StaticResource RacksWindowIconButton}" Click="CloseButton_Click">
                <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
            </Button>

            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,6,0,0">
                <Image Source="/ico.png" Height="72" Margin="0,0,0,12" HorizontalAlignment="Center"/>
                <TextBlock Text="Racks" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="VersionTextBlock" Margin="0,4,0,0" FontSize="13"
                           Foreground="{StaticResource RacksMutedForeground}" HorizontalAlignment="Center"/>
                <Border Height="1" Background="#1AFFFFFF" Margin="20,14"/>
                <TextBlock Text="MIT License" FontSize="12"
                           Foreground="{StaticResource RacksMutedForeground}" HorizontalAlignment="Center"/>
                <TextBlock Text="Free and open source" Margin="0,2,0,0" FontSize="11"
                           Foreground="#66FFFFFF" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
