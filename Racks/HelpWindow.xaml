<ui:FluentWindow x:Class="Racks.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        ExtendsContentIntoTitleBar="True"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="#F0202020"
        Foreground="White"
        Title="Racks — cheatsheet"
        Width="600"
        Height="640">
    <Grid>
        <ui:TitleBar Padding="8,0,0,0" Title="Racks — cheatsheet" Height="30"
                     CanMaximize="False" ShowMinimize="False"
                     ApplicationTheme="Dark" VerticalAlignment="Top"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="20,40,20,20">
            <StackPanel>
                <TextBlock Text="Make racks" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.85">
                    <Run Text="• New rack — tray menu &gt; New rack. Drag any shortcut/file/folder in; a .lnk is created in the sandbox. The original is never moved."/>
                    <LineBreak/>
                    <Run Text="• New folder rack — tray menu &gt; New folder rack. Drag a folder onto the empty rack to bind it to that folder on disk."/>
                </TextBlock>

                <TextBlock Text="Drag and drop" FontWeight="Bold" FontSize="14" Margin="0,16,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.85">
                    <Run Text="• Default: the dropped item is MOVED into the rack — no duplicate on Desktop, the rack is its new home."/>
                    <LineBreak/>
                    <Run Text="• Hold Ctrl while dropping: create a shortcut instead, source stays in place."/>
                    <LineBreak/>
                    <Run Text="• Hold Shift while dropping: force move even if the rack is set to link-mode."/>
                    <LineBreak/>
                    <Run Text="• Per-rack default: right-click rack title &gt; Create shortcuts instead of moving."/>
                    <LineBreak/>
                    <Run Text="• Safety: virtual racks move into a private sandbox under %AppData%\Racks. Removing a rack only deletes inside that sandbox — real folders are never touched."/>
                </TextBlock>

                <TextBlock Text="Rack title" FontWeight="Bold" FontSize="14" Margin="0,16,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.85">
                    <Run Text="• Double-click title: rename in-place (Enter saves, Esc cancels)."/>
                    <LineBreak/>
                    <Run Text="• Right-click title bar: full rack menu."/>
                    <LineBreak/>
                    <Run Text="• Scroll on title bar: bring rack forward / send it behind."/>
                </TextBlock>

                <TextBlock Text="Items" FontWeight="Bold" FontSize="14" Margin="0,16,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.85">
                    <Run Text="• Type while hovering a rack: instant search/filter."/>
                    <LineBreak/>
                    <Run Text="• Ctrl + Scroll: resize icons."/>
                    <LineBreak/>
                    <Run Text="• Alt + drag an item: reorder within the rack."/>
                    <LineBreak/>
                    <Run Text="• Drag an item out: drops the real path (Explorer/apps accept it)."/>
                </TextBlock>

                <TextBlock Text="Global hotkeys" FontWeight="Bold" FontSize="14" Margin="0,16,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.85">
                    <Run Text="• Ctrl + Shift + Space: open the cross-rack quick finder. Type to filter, ↑↓ to navigate, Enter opens, Esc dismisses."/>
                    <LineBreak/>
                    <Run Text="• Ctrl + Shift + N: instantly create a new virtual rack."/>
                </TextBlock>

                <TextBlock Text="Per-rack settings (right-click title)" FontWeight="Bold" FontSize="14" Margin="0,16,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.85">
                    <Run Text="• Snap to grid: 16px grid; hold Alt while dragging the rack to bypass."/>
                    <LineBreak/>
                    <Run Text="• Pin to top: rack stays above all other windows."/>
                    <LineBreak/>
                    <Run Text="• Auto-route from Desktop: regex matched against new files on the Desktop; matches are auto-moved into this rack (no duplicate)."/>
                    <LineBreak/>
                    <Run Text="• Set background image: PNG/JPG/etc. fills the rack."/>
                    <LineBreak/>
                    <Run Text="• Theme: 6 one-click looks (Dark, Light, Glass, Neon, Solarized Dark/Light)."/>
                    <LineBreak/>
                    <Run Text="• Refresh thumbnails: re-fetches every icon (fix stale/blank icons)."/>
                    <LineBreak/>
                    <Run Text="• Show in Explorer: opens the rack's backing folder."/>
                    <LineBreak/>
                    <Run Text="• Reset position: recenter the rack on the primary monitor."/>
                    <LineBreak/>
                    <Run Text="• Duplicate rack: copies colors/fonts/regex/snap into a new empty rack."/>
                </TextBlock>

                <TextBlock Text="Global tray menu" FontWeight="Bold" FontSize="14" Margin="0,16,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.85">
                    <Run Text="• Hide desktop icons: toggles Windows' SHELLDLL_DefView. Use it for a clean racks-only desktop."/>
                    <LineBreak/>
                    <Run Text="• Hide racks on top-right corner: move cursor to the top-right hot zone to peek the desktop."/>
                    <LineBreak/>
                    <Run Text="• Lock all racks: freeze every rack at once."/>
                    <LineBreak/>
                    <Run Text="• Double click on desktop to hide every frame: existing global gesture."/>
                    <LineBreak/>
                    <Run Text="• Export racks…/Import racks…: backup or transfer your entire layout via a single JSON file."/>
                </TextBlock>

                <TextBlock Text="Safety" FontWeight="Bold" FontSize="14" Margin="0,16,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.85">
                    <Run Text="• Removing a rack never deletes real folders. Recursive deletes are sandboxed to %AppData%\Racks\VirtualFrames."/>
                    <LineBreak/>
                    <Run Text="• Drops into a folder-backed rack go into the folder you chose. Drops into a virtual rack go into the private sandbox."/>
                    <LineBreak/>
                    <Run Text="• Legacy desktop-organizer setups are migrated on first launch."/>
                </TextBlock>

                <TextBlock Text="Close" FontWeight="Bold" FontSize="14" Margin="0,16,0,4"/>
                <TextBlock TextWrapping="Wrap" Opacity="0.85" Margin="0,0,0,16">
                    <Run Text="Press Esc or click the X."/>
                </TextBlock>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
