<Window x:Class="Racks.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Racks"
        xmlns:properties="clr-namespace:Racks.Properties;assembly=Racks"
        xmlns:prop="clr-namespace:Racks.Properties"
        mc:Ignorable="d"
        Background="Transparent"
        AllowsTransparency="True"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        WindowStyle="None"
        ResizeMode="NoResize"
        Height="650"
        Width="480"
        Closing="FluentWindow_Closing">
    <Border CornerRadius="14" BorderThickness="1" Margin="16"
            Background="{StaticResource RacksCardBackground}"
            BorderBrush="{StaticResource RacksCardBorder}">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="15" Opacity="0.5"/>
        </Border.Effect>
    <Grid>
        <StackPanel>
            <!-- Custom title strip (drag + about + close), matching the app-wide card look. -->
            <Grid Height="46" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Image Source="/ico.png" Width="18" Height="18" Margin="0,0,8,0"/>
                    <TextBlock Text="{x:Static prop:Lang.RacksSettings_TitleBarText}" FontSize="13" FontWeight="SemiBold"
                               Foreground="#DDFFFFFF" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button x:Name="AboutButton" Style="{StaticResource RacksWindowIconButton}" Click="AboutButton_Click" ToolTip="About">
                        <ui:SymbolIcon Symbol="Info24" FontSize="15"/>
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource RacksWindowIconButton}" Click="CloseButton_Click">
                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
            <StackPanel Orientation="Vertical" Margin="10,10,0,0" >
            </StackPanel>

            <StackPanel >
                <ui:Button x:Name="ExportSettingsButton" Content="{x:Static prop:Lang.RacksSettings_ExportSettings}" Click="ExportSettingsButton_Click" Margin="10,10,0,0"/>
                <StackPanel Orientation="Horizontal">
                    <ui:Button x:Name="DefaultFrameStyleButton" Content="{x:Static prop:Lang.RacksSettings_DefaultFrameStyle}"  Margin="10,20,0,0" Click="DefaultFrameStyleButton_Click"/>
                    <ui:Button x:Name="ResetDefaultFrameStyleButton" Content="{x:Static prop:Lang.RacksSettings_ResetDefaultStyle}" Icon="{ui:SymbolIcon ArrowReset24}" Margin="10,20,0,0" Click="ResetDefaultFrameStyleButton_Click" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <ui:Button x:Name="ReloadAllFramesButton" Content="{x:Static prop:Lang.RacksSettings_ReloadAllFramesButton}" Click="ReloadAllFramesButton_Click" Margin="10,20,0,0"/>
                    <ui:Button x:Name="ManageFrameButton" Content="{x:Static prop:Lang.RacksSettings_ManageFrameButton}" Click="ManageFrameButton_Click" Margin="10,20,0,0"/>
                </StackPanel>

                <ui:ToggleSwitch x:Name="AutoUpdateToggleSwitch" Content="{x:Static prop:Lang.RacksSettings_AutoUpdate}" Margin="10,20,0,0" Click="AutoUpdateToggleSwitch_Click"/>
                <ui:ToggleSwitch x:Name="DoubleClickToHideSwitch" Content="{x:Static prop:Lang.RacksSettings_DoubleClickHide}" Margin="10,20,0,0" Click="DoubleClickToHideSwitch_Click"/>

                <Separator HorizontalAlignment="Center" Margin="20,10,20,10" Width="461"/>


                <StackPanel>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Right">
                            <Border HorizontalAlignment="Left" Height="25" Background="#FF333333" Padding="8,2" CornerRadius="4"  Margin="0,0,8,0">
                                <TextBlock Text="ALT"  Foreground="LightGray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border HorizontalAlignment="Left" Height="25" Background="#FF333333" Padding="8,2" CornerRadius="4">
                                <TextBlock Text="{x:Static prop:Lang.RacksSettings_Drag}"  Foreground="LightGray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Grid.Column="1" Text="{x:Static prop:Lang.RacksSettings_SnapDescription}" TextWrapping="Wrap" Foreground="LightGray" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            <TextBlock Grid.Column="1" Text="{x:Static prop:Lang.RacksSettings_ReorderDescription}" TextWrapping="Wrap" Foreground="LightGray" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>

                    </Grid>

                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Right">
                            <Border HorizontalAlignment="Left" Height="25" Background="#FF333333" Padding="8,2" CornerRadius="4"  Margin="0,0,8,0">
                                <TextBlock Text="CTRL" Foreground="LightGray"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border HorizontalAlignment="Left" Height="25" Background="#FF333333" Padding="8,2" CornerRadius="4">
                                <TextBlock Text="{x:Static prop:Lang.RacksSettings_Scroll}" Foreground="LightGray"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{x:Static prop:Lang.RacksSettings_ChangeIconSizeDescription}" TextWrapping="Wrap" Foreground="LightGray"  VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>

                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Right">
                            <Border HorizontalAlignment="Left" Height="25" Background="#FF333333" Padding="8,2" CornerRadius="4">
                                <TextBlock Text="F2" Foreground="LightGray"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{x:Static prop:Lang.RacksSettings_RenameFilesDescription}" TextWrapping="Wrap" Foreground="LightGray"  VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </Grid>

                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border HorizontalAlignment="Right" Height="25" Background="#FF333333" Padding="8,2" CornerRadius="4" >
                            <TextBlock Text="{x:Static prop:Lang.RacksSettings_Scroll}"  Foreground="LightGray" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <TextBlock Grid.Column="1" Text="{x:Static prop:Lang.RacksSettings_ScrollUpDescription}" TextWrapping="Wrap" Foreground="LightGray" VerticalAlignment="Center" Margin="16,0,0,0"/>
                            <TextBlock Grid.Column="1" Text="{x:Static prop:Lang.RacksSettings_ScrollDownDescription}" TextWrapping="Wrap" Foreground="LightGray" VerticalAlignment="Center" Margin="16,0,0,0"/>
                        </StackPanel>

                    </Grid>

                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Bottom promo strip (Ko-fi badge + DragWin + EverythingQuickSearch ads) was
             removed in the Racks fork. The space is now empty by design — keeps the
             settings dialog clean and free of cross-app promotion. -->



        <StackPanel Orientation="Horizontal"  HorizontalAlignment="Right" Margin="0,0,16,10" VerticalAlignment="Bottom">
            <Label Content="{x:Static prop:Lang.RacksSettings_MadewithSpace}" HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="DimGray"/>
            <ui:SymbolIcon Symbol="Heart20" Filled="True" Margin="0,-2,0,0" Foreground="DimGray"/>
        </StackPanel>

    </Grid>
    </Border>
</Window>
