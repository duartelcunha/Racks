<ui:FluentWindow x:Class="Racks.RackSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:Racks"
        xmlns:colorpick="clr-namespace:Racks.ColorPicker"
        xmlns:prop="clr-namespace:Racks.Properties"
        ExtendsContentIntoTitleBar="True"
        mc:Ignorable="d"
        Background="#CC1B1B1B"
        WindowStyle="None"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        RenderOptions.BitmapScalingMode="HighQuality"
        Width="520"
        Height="640"
        MinHeight="480"
        MinWidth="440"
        ShowInTaskbar="False"
        Opacity="0"
        WindowStartupLocation="Manual"
        Loaded="Window_Loaded"
        Closed="Window_Closed">

    <ui:FluentWindow.Resources>

        <SolidColorBrush x:Key="SectionCardBackground" Color="#0DFFFFFF"/>
        <SolidColorBrush x:Key="SectionCardBorder" Color="#1AFFFFFF"/>
        <SolidColorBrush x:Key="NavItemHoverBackground" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="NavItemSelectedBackground" Color="#26FFFFFF"/>
        <SolidColorBrush x:Key="NavItemSelectedAccent" Color="#FF3DA9FC"/>
        <SolidColorBrush x:Key="MutedForeground" Color="#A6FFFFFF"/>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Foreground" Value="#9CFFFFFF"/>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Foreground" Value="#E6FFFFFF"/>
        </Style>

        <Style x:Key="FieldHelp" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Foreground" Value="#70FFFFFF"/>
        </Style>

        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SectionCardBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource SectionCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10,12,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="NavPillItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="4,2,4,2"/>
            <Setter Property="Padding" Value="0,8,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#E6FFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                CornerRadius="6"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource NavItemHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource NavItemSelectedBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <VisualBrush x:Key="CheckerboardBrush"
                     Stretch="Uniform" TileMode="Tile"
                     Viewport="0,0,8,8"
                     ViewboxUnits="RelativeToBoundingBox"
                     ViewportUnits="Absolute">
            <VisualBrush.Visual>
                <Canvas Width="8" Height="8">
                    <Rectangle Width="4" Height="4" Fill="#FF6B6B6B"/>
                    <Rectangle Width="4" Height="4" Fill="#FF424242" Canvas.Left="4"/>
                    <Rectangle Width="4" Height="4" Fill="#FF424242" Canvas.Top="4"/>
                    <Rectangle Width="4" Height="4" Fill="#FF6B6B6B" Canvas.Left="4" Canvas.Top="4"/>
                </Canvas>
            </VisualBrush.Visual>
        </VisualBrush>

    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Name="Titlebar"
                     Grid.Row="0"
                     Padding="10,0,0,0"
                     Height="32"
                     CanMaximize="False"
                     ShowMinimize="False"
                     ApplicationTheme="Dark"
                     ShowMaximize="False"
                     Title="{x:Static prop:Lang.FrameSettings_TitleBarText}"
                     CloseClicked="Titlebar_CloseClicked">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/ico.png" Margin="0,0,6,0"/>
            </ui:TitleBar.Icon>
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal">
                    <ui:Button x:Name="ChangeStyleDropDownButton"
                               Icon="{ui:SymbolIcon PaintBrush20}"
                               ToolTip="{x:Static prop:Lang.FrameSettings_ChangeStyle}"
                               VerticalAlignment="Center"
                               Margin="0,0,4,0"
                               Width="30" Height="28" Padding="0"
                               Click="ChangeStyleDropDownButton_Click"/>
                    <ui:Button x:Name="ChangeFolderButton"
                               Icon="{ui:SymbolIcon Folder20}"
                               ToolTip="{x:Static prop:Lang.FrameSettings_ChangeFolder}"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"
                               Width="30" Height="28" Padding="0"
                               Click="ChangeFolderButton_Click"/>
                </StackPanel>
            </ui:TitleBar.TrailingContent>
        </ui:TitleBar>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#08FFFFFF" BorderBrush="#14FFFFFF" BorderThickness="0,0,1,0">
                <ListBox x:Name="SectionList"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource NavPillItem}"
                         SelectionChanged="SectionList_SelectionChanged"
                         Padding="0,8,0,8">
                    <ListBoxItem x:Name="NavAppearance" IsSelected="True" ToolTip="Appearance">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="PaintBrush20" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Style" FontSize="10" Margin="0,3,0,0" HorizontalAlignment="Center" Foreground="#B0FFFFFF"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="NavTitleBar" ToolTip="Title bar">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="TextHeader120" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Title" FontSize="10" Margin="0,3,0,0" HorizontalAlignment="Center" Foreground="#B0FFFFFF"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="NavItems" ToolTip="Items">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="Apps20" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Items" FontSize="10" Margin="0,3,0,0" HorizontalAlignment="Center" Foreground="#B0FFFFFF"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="NavWindow" ToolTip="Window position and size">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="Window20" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Window" FontSize="10" Margin="0,3,0,0" HorizontalAlignment="Center" Foreground="#B0FFFFFF"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="NavFolder" ToolTip="Folder behavior">
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <ui:SymbolIcon Symbol="FolderOpen20" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Folder" FontSize="10" Margin="0,3,0,0" HorizontalAlignment="Center" Foreground="#B0FFFFFF"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </Border>

            <Grid Grid.Column="1">

                <Popup x:Name="uiFlyout"
                       AllowsTransparency="True"
                       StaysOpen="False"
                       PopupAnimation="Fade"
                       Placement="Bottom"
                       HorizontalOffset="0"
                       VerticalOffset="4">
                    <Border Background="#FF1F1F1F"
                            BorderBrush="#33FFFFFF"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Effect="{x:Null}">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="PickerScale" ScaleX="0.96" ScaleY="0.96" CenterX="0" CenterY="0"/>
                        </Border.RenderTransform>
                        <StackPanel x:Name="ColorCard"/>
                    </Border>
                </Popup>

                <!-- ====================  STYLE / APPEARANCE  ==================== -->
                <ScrollViewer x:Name="PageAppearance"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14,12,14,14">
                    <StackPanel HorizontalAlignment="Stretch">

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="PREMIUM UI &amp; OPTIMIZATION" Style="{StaticResource SectionHeader}"/>
                                <CheckBox x:Name="DropShadowCheckBox"
                                          Content="Enable Drop Shadow"
                                          Margin="0,0,0,8"
                                          Checked="DropShadowCheckBox_Checked"
                                          Unchecked="DropShadowCheckBox_Checked"/>
                                <CheckBox x:Name="GradientBackgroundCheckBox"
                                          Content="Enable Gradient Background"
                                          Margin="0,0,0,8"
                                          Checked="GradientBackgroundCheckBox_Checked"
                                          Unchecked="GradientBackgroundCheckBox_Checked"/>
                                <CheckBox x:Name="DisableAnimationsCheckBox"
                                          Content="Disable Animations (Performance)"
                                          Margin="0,0,0,8"
                                          Checked="DisableAnimationsCheckBox_Checked"
                                          Unchecked="DisableAnimationsCheckBox_Checked"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="BORDER" Style="{StaticResource SectionHeader}"/>

                                <CheckBox x:Name="BorderEnabledCheckBox"
                                          Content="Show a border"
                                          Margin="0,0,0,8"
                                          Checked="BorderEnabledCheckBox_Checked"
                                          Unchecked="BorderEnabledCheckBox_Checked"/>

                                <TextBlock Text="{x:Static prop:Lang.FrameSettings_BorderColor}" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,8">
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4"
                                               IsHitTestVisible="False" Panel.ZIndex="2"
                                               Fill="{StaticResource CheckerboardBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4" Panel.ZIndex="3"
                                               Fill="{Binding Foreground, ElementName=BorderColorTextBoxIcon}"
                                               HorizontalAlignment="Right" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <ui:TextBox x:Name="BorderColorTextBox"
                                                IconPlacement="Right"
                                                PlaceholderText="#FFFFFF"
                                                HorizontalAlignment="Stretch"
                                                TextChanged="TextChangedHandler">
                                        <ui:TextBox.Icon>
                                            <ui:SymbolIcon Symbol="Square20" Filled="True" FontSize="30"
                                                           x:Name="BorderColorTextBoxIcon"
                                                           Cursor="Hand"
                                                           MouseUp="BorderColorTextBoxIcon_MouseUp"/>
                                        </ui:TextBox.Icon>
                                    </ui:TextBox>
                                </Grid>

                                <CheckBox x:Name="ActiveBorderEnabledCheckBox"
                                          Content="Use a different color when active"
                                          Margin="0,4,0,8"
                                          Checked="ActiveBorderEnabledCheckBox_Checked"
                                          Unchecked="ActiveBorderEnabledCheckBox_Checked"/>

                                <Grid>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4"
                                               IsHitTestVisible="False" Panel.ZIndex="2"
                                               Fill="{StaticResource CheckerboardBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4" Panel.ZIndex="3"
                                               Fill="{Binding Foreground, ElementName=ActiveBorderColorTextBoxIcon}"
                                               HorizontalAlignment="Right" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <ui:TextBox x:Name="ActiveBorderColorTextBox"
                                                IconPlacement="Right"
                                                PlaceholderText="#FFFFFF"
                                                HorizontalAlignment="Stretch"
                                                TextChanged="TextChangedHandler">
                                        <ui:TextBox.Icon>
                                            <ui:SymbolIcon x:Name="ActiveBorderColorTextBoxIcon"
                                                           Symbol="Square20" Filled="True" FontSize="30"
                                                           Cursor="Hand"
                                                           MouseUp="ActiveBorderColorTextBoxIcon_MouseUp"/>
                                        </ui:TextBox.Icon>
                                    </ui:TextBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="BACKGROUND" Style="{StaticResource SectionHeader}"/>

                                <TextBlock Text="{x:Static prop:Lang.FrameSettings_BackgroundColor}" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,8">
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4"
                                               IsHitTestVisible="False" Panel.ZIndex="2"
                                               Fill="{StaticResource CheckerboardBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4" Panel.ZIndex="3"
                                               Fill="{Binding Foreground, ElementName=ListViewBackgroundColorTextBoxIcon}"
                                               HorizontalAlignment="Right" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <ui:TextBox x:Name="ListViewBackgroundColorTextBox"
                                                IconPlacement="Right"
                                                PlaceholderText="#0C000000"
                                                HorizontalAlignment="Stretch"
                                                TextChanged="TextChangedHandler">
                                        <ui:TextBox.Icon>
                                            <ui:SymbolIcon Symbol="Square20" Filled="True" FontSize="30"
                                                           x:Name="ListViewBackgroundColorTextBoxIcon"
                                                           Cursor="Hand"
                                                           MouseUp="ListViewBackgroundColorTextBoxIcon_MouseUp"/>
                                        </ui:TextBox.Icon>
                                    </ui:TextBox>
                                </Grid>

                                <CheckBox x:Name="ActiveBackgroundEnabledCheckBox"
                                          Content="Use a different color when active"
                                          Margin="0,4,0,8"
                                          Checked="ActiveBackgroundEnabledCheckBox_Checked"
                                          Unchecked="ActiveBackgroundEnabledCheckBox_Checked"/>

                                <Grid>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4"
                                               IsHitTestVisible="False" Panel.ZIndex="2"
                                               Fill="{StaticResource CheckerboardBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4" Panel.ZIndex="3"
                                               Fill="{Binding Foreground, ElementName=ActiveBackgroundColorTextBoxIcon}"
                                               HorizontalAlignment="Right" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <ui:TextBox x:Name="ActiveBackgroundColorTextBox"
                                                IconPlacement="Right"
                                                PlaceholderText="#FFFFFF"
                                                HorizontalAlignment="Stretch"
                                                TextChanged="TextChangedHandler">
                                        <ui:TextBox.Icon>
                                            <ui:SymbolIcon x:Name="ActiveBackgroundColorTextBoxIcon"
                                                           Symbol="Square20" Filled="True" FontSize="30"
                                                           Cursor="Hand"
                                                           MouseUp="ActiveBackgroundColorTextBoxIcon_MouseUp"/>
                                        </ui:TextBox.Icon>
                                    </ui:TextBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="OPACITY &amp; MOTION" Style="{StaticResource SectionHeader}"/>

                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static prop:Lang.FrameSettings_IdleOpacityLabel}" Style="{StaticResource FieldLabel}" Margin="0"/>
                                    <TextBlock Grid.Column="1" x:Name="IdleOpacityLabel"
                                               Text="0%"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource NavItemSelectedAccent}"/>
                                </Grid>
                                <Slider x:Name="IdleOpacitySlider"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Center" IsSnapToTickEnabled="True"
                                        Minimum="0" Maximum="10"
                                        TickFrequency="1"
                                        Margin="0,0,0,12"
                                        ValueChanged="Slider_ValueChanged"/>

                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static prop:Lang.FrameSettings_AnimationSpeed}" Style="{StaticResource FieldLabel}" Margin="0"/>
                                    <TextBlock Grid.Column="1" x:Name="AnimationSpeedLabel"
                                               Text="0.0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource NavItemSelectedAccent}"/>
                                </Grid>
                                <Slider x:Name="AnimationSpeedSlider"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Center" IsSnapToTickEnabled="True"
                                        Minimum="0" Maximum="10"
                                        TickFrequency="1"
                                        ValueChanged="Slider_ValueChanged"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ====================  TITLE BAR  ==================== -->
                <ScrollViewer x:Name="PageTitleBar"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14,12,14,14"
                              Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Stretch">

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="TEXT" Style="{StaticResource SectionHeader}"/>

                                <TextBlock Text="{x:Static prop:Lang.FrameSettings_TitleBarTextText}" Style="{StaticResource FieldLabel}"/>
                                <ui:TextBox x:Name="TitleTextBox"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,0,0,10"
                                            TextChanged="TextChangedHandler"/>

                                <TextBlock Text="{x:Static prop:Lang.FrameSettings_Font}" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="TitleTextAutoSuggestionBox"
                                          IsEditable="True"
                                          IsTextSearchEnabled="True"
                                          IsTextSearchCaseSensitive="False"
                                          StaysOpenOnEdit="True"
                                          MaxDropDownHeight="320"
                                          ScrollViewer.VerticalScrollBarVisibility="Visible"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          ScrollViewer.CanContentScroll="True"
                                          VirtualizingStackPanel.IsVirtualizing="True"
                                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,10">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontFamily="{Binding}" FontSize="14" Padding="2,1,2,1"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{x:Static prop:Lang.FrameSettings_TextSize}" Style="{StaticResource FieldLabel}"/>
                                        <ui:NumberBox x:Name="TitleFontSizeNumberBox"
                                                      Minimum="8" Maximum="72"
                                                      SmallChange="1"
                                                      LargeChange="2"
                                                      SpinButtonPlacementMode="Inline"
                                                      HorizontalAlignment="Stretch"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{x:Static prop:Lang.FrameSettings_TextAlignment}" Style="{StaticResource FieldLabel}"/>
                                        <ComboBox x:Name="TitleTextAlignmentComboBox"
                                                  HorizontalAlignment="Stretch"
                                                  SelectionChanged="TitleTextAlignmentComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Left"/>
                                            <ComboBoxItem Content="Center"/>
                                            <ComboBoxItem Content="Right"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="COLORS" Style="{StaticResource SectionHeader}"/>

                                <TextBlock Text="{x:Static prop:Lang.FrameSettings_BackgroundColor}" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,10">
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4"
                                               IsHitTestVisible="False" Panel.ZIndex="2"
                                               Fill="{StaticResource CheckerboardBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4" Panel.ZIndex="3"
                                               Fill="{Binding Foreground, ElementName=TitleBarColorTextBoxIcon}"
                                               HorizontalAlignment="Right" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <ui:TextBox x:Name="TitleBarColorTextBox"
                                                IconPlacement="Right"
                                                PlaceholderText="#0C000000"
                                                HorizontalAlignment="Stretch"
                                                TextChanged="TextChangedHandler">
                                        <ui:TextBox.Icon>
                                            <ui:SymbolIcon Symbol="Square20" Filled="True" FontSize="30"
                                                           x:Name="TitleBarColorTextBoxIcon"
                                                           Cursor="Hand"
                                                           MouseUp="TitleBarColorTextBoxIcon_MouseUp"/>
                                        </ui:TextBox.Icon>
                                    </ui:TextBox>
                                </Grid>

                                <TextBlock Text="{x:Static prop:Lang.FrameSettings_TextColor}" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,10">
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4"
                                               IsHitTestVisible="False" Panel.ZIndex="2"
                                               Fill="{StaticResource CheckerboardBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4" Panel.ZIndex="3"
                                               Fill="{Binding Foreground, ElementName=TitleTextColorTextBoxIcon}"
                                               HorizontalAlignment="Right" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <ui:TextBox x:Name="TitleTextColorTextBox"
                                                IconPlacement="Right"
                                                PlaceholderText="#FFFFFF"
                                                HorizontalAlignment="Stretch"
                                                TextChanged="TextChangedHandler">
                                        <ui:TextBox.Icon>
                                            <ui:SymbolIcon Symbol="Square20" Filled="True" FontSize="30"
                                                           x:Name="TitleTextColorTextBoxIcon"
                                                           Cursor="Hand"
                                                           MouseUp="TitleTextColorTextBoxIcon_MouseUp"/>
                                        </ui:TextBox.Icon>
                                    </ui:TextBox>
                                </Grid>

                                <CheckBox x:Name="ActiveTitleTextEnabledCheckBox"
                                          Content="Use a different text color when active"
                                          Margin="0,4,0,8"
                                          Checked="ActiveTitleTextEnabledCheckBox_Checked"
                                          Unchecked="ActiveTitleTextEnabledCheckBox_Checked"/>
                                <Grid>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4"
                                               IsHitTestVisible="False" Panel.ZIndex="2"
                                               Fill="{StaticResource CheckerboardBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4" Panel.ZIndex="3"
                                               Fill="{Binding Foreground, ElementName=ActiveTitleTextColorTextBoxIcon}"
                                               HorizontalAlignment="Right" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <ui:TextBox x:Name="ActiveTitleTextColorTextBox"
                                                IconPlacement="Right"
                                                PlaceholderText="#FFFFFF"
                                                HorizontalAlignment="Stretch"
                                                TextChanged="TextChangedHandler">
                                        <ui:TextBox.Icon>
                                            <ui:SymbolIcon x:Name="ActiveTitleTextColorTextBoxIcon"
                                                           Symbol="Square20" Filled="True" FontSize="30"
                                                           Cursor="Hand"
                                                           MouseUp="ActiveTitleTextColorTextBoxIcon_MouseUp"/>
                                        </ui:TextBox.Icon>
                                    </ui:TextBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="ICONS" Style="{StaticResource SectionHeader}"/>
                                <CheckBox x:Name="ShowFileExtensionIconCheckBox"
                                          Content="{x:Static prop:Lang.FrameSettings_ShowFileExtensionIcon}"
                                          Margin="0,0,0,6"
                                          Checked="ShowFileExtensionIconCheckBox_Checked"
                                          Unchecked="ShowFileExtensionIconCheckBox_Checked"/>
                                <CheckBox x:Name="ShowHiddenFilesIconCheckBox"
                                          Content="{x:Static prop:Lang.FrameSettings_ShowHiddenFilesIcon}"
                                          Margin="0,0,0,6"
                                          Checked="ShowHiddenFilesIconCheckBox_Checked"
                                          Unchecked="ShowHiddenFilesIconCheckBox_Checked"/>
                                <CheckBox x:Name="HideTitleBarIconsWhenInactive_CheckBox"
                                          Checked="HideTitleBarIconsWhenInactive_CheckBox_Checked"
                                          Unchecked="HideTitleBarIconsWhenInactive_CheckBox_Checked">
                                    <TextBlock Text="{x:Static prop:Lang.FrameSettings_HideTitleBarIconsWhenInactive}" TextWrapping="Wrap"/>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ====================  ITEMS  ==================== -->
                <ScrollViewer x:Name="PageItems"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14,12,14,14"
                              Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Stretch">

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="LABEL COLORS" Style="{StaticResource SectionHeader}"/>

                                <TextBlock Text="{x:Static prop:Lang.FrameSettings_TextColor}" Style="{StaticResource FieldLabel}"/>
                                <Grid Margin="0,0,0,10">
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4"
                                               IsHitTestVisible="False" Panel.ZIndex="2"
                                               Fill="{StaticResource CheckerboardBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4" Panel.ZIndex="3"
                                               Fill="{Binding Foreground, ElementName=ListViewFontColorTextBoxIcon}"
                                               HorizontalAlignment="Right" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <ui:TextBox x:Name="ListViewFontColorTextBox"
                                                IconPlacement="Right"
                                                PlaceholderText="#FFFFFF"
                                                HorizontalAlignment="Stretch"
                                                TextChanged="TextChangedHandler">
                                        <ui:TextBox.Icon>
                                            <ui:SymbolIcon Symbol="Square20" Filled="True" FontSize="30"
                                                           x:Name="ListViewFontColorTextBoxIcon"
                                                           Cursor="Hand"
                                                           MouseUp="ListViewFontColorTextBoxIcon_MouseUp"/>
                                        </ui:TextBox.Icon>
                                    </ui:TextBox>
                                </Grid>

                                <TextBlock Text="{x:Static prop:Lang.FrameSettings_TextShadowColor}" Style="{StaticResource FieldLabel}"/>
                                <Grid>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4"
                                               IsHitTestVisible="False" Panel.ZIndex="2"
                                               Fill="{StaticResource CheckerboardBrush}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Rectangle Width="20" Height="20" RadiusX="4" RadiusY="4" Panel.ZIndex="3"
                                               Fill="{Binding Foreground, ElementName=ListViewFontShadowColorTextBoxIcon}"
                                               HorizontalAlignment="Right" IsHitTestVisible="False"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <ui:TextBox x:Name="ListViewFontShadowColorTextBox"
                                                IconPlacement="Right"
                                                PlaceholderText="#000000"
                                                HorizontalAlignment="Stretch"
                                                TextChanged="TextChangedHandler">
                                        <ui:TextBox.Icon>
                                            <ui:SymbolIcon Symbol="Square20" Filled="True" FontSize="30"
                                                           x:Name="ListViewFontShadowColorTextBoxIcon"
                                                           Cursor="Hand"
                                                           MouseUp="ListViewFontShadowColorTextBoxIcon_MouseUp"/>
                                        </ui:TextBox.Icon>
                                    </ui:TextBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="FONT &amp; SIZE" Style="{StaticResource SectionHeader}"/>

                                <TextBlock Text="{x:Static prop:Lang.FrameSettings_Font}" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="ItemTextAutoSuggestionBox"
                                          IsEditable="True"
                                          IsTextSearchEnabled="True"
                                          IsTextSearchCaseSensitive="False"
                                          StaysOpenOnEdit="True"
                                          MaxDropDownHeight="320"
                                          ScrollViewer.VerticalScrollBarVisibility="Visible"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          ScrollViewer.CanContentScroll="True"
                                          VirtualizingStackPanel.IsVirtualizing="True"
                                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,12">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontFamily="{Binding}" FontSize="14" Padding="2,1,2,1"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>

                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static prop:Lang.FrameSettings_IconSize}" Style="{StaticResource FieldLabel}" Margin="0"/>
                                    <TextBlock Grid.Column="1" x:Name="IconSizeLabel"
                                               Text="0"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource NavItemSelectedAccent}"/>
                                </Grid>
                                <Slider x:Name="IconSizeSlider"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Center" IsSnapToTickEnabled="True"
                                        Minimum="1" Maximum="64"
                                        TickFrequency="1"
                                        ValueChanged="Slider_ValueChanged"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="FILTERS" Style="{StaticResource SectionHeader}"/>

                                <TextBlock Text="{x:Static prop:Lang.FrameSettings_ShowFilesRegex}" Style="{StaticResource FieldLabel}"/>
                                <ui:TextBox x:Name="FileFilterRegexTextBox"
                                            HorizontalAlignment="Stretch"
                                            PlaceholderText="regex"
                                            Margin="0,0,0,10"
                                            TextChanged="TextChangedHandler"/>

                                <TextBlock Text="{x:Static prop:Lang.FrameSettings_HideFilesRegex}" Style="{StaticResource FieldLabel}"/>
                                <ui:TextBox x:Name="FileFilterHideRegexTextBox"
                                            HorizontalAlignment="Stretch"
                                            PlaceholderText="regex"
                                            TextChanged="TextChangedHandler"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="DISPLAY" Style="{StaticResource SectionHeader}"/>
                                <CheckBox x:Name="ShowDisplayNameCheckBox"
                                          Content="{x:Static prop:Lang.FrameSettings_ShowIconText}"
                                          Margin="0,0,0,6"
                                          Checked="ShowDisplayNameCheckBox_Checked"
                                          Unchecked="ShowDisplayNameCheckBox_Checked"/>
                                <CheckBox x:Name="ShowShortcutArrowCheckBox"
                                          Margin="0,0,0,6"
                                          Checked="ShowShortcutArrowCheckBox_Checked"
                                          Unchecked="ShowShortcutArrowCheckBox_Unchecked">
                                    <TextBlock Text="{x:Static prop:Lang.FrameSettings_ShowShortcutArrow}" TextWrapping="Wrap"/>
                                </CheckBox>
                                <CheckBox x:Name="ShowLastAccessedToFirstRowCheckBox"
                                          Checked="ShowLastAccessedToFirstRowCheckBox_Checked"
                                          Unchecked="ShowLastAccessedToFirstRowCheckBox_Unchecked">
                                    <TextBlock Text="{x:Static prop:Lang.FrameSettings_ShowLastAccessedItem}" TextWrapping="Wrap"/>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="GRAYSCALE" Style="{StaticResource SectionHeader}"/>

                                <CheckBox x:Name="GrayScaleEnabled_CheckBox"
                                          Checked="GrayScaleEnabled_CheckBox_Checked"
                                          Unchecked="GrayScaleEnabled_CheckBox_Checked"
                                          Margin="0,0,0,6">
                                    <TextBlock Text="{x:Static prop:Lang.FrameSettings_GrayscaleEnable}" TextWrapping="Wrap"/>
                                </CheckBox>
                                <CheckBox x:Name="GrayScaleEnabled_InactiveOnly_CheckBox"
                                          Checked="GrayScaleEnabled_InactiveOnly_CheckBox_Checked"
                                          Unchecked="GrayScaleEnabled_InactiveOnly_CheckBox_Checked"
                                          Margin="22,0,0,10"
                                          Visibility="Collapsed">
                                    <TextBlock Text="{x:Static prop:Lang.FrameSettings_GrayScaleEnabledInactiveOnly}" TextWrapping="Wrap"/>
                                </CheckBox>

                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Static prop:Lang.FrameSettings_GrayScaleMaxLevel}" Style="{StaticResource FieldLabel}" Margin="0"/>
                                    <TextBlock Grid.Column="1" x:Name="MaxGrayScaleStrengthLabel"
                                               Text="0%"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource NavItemSelectedAccent}"/>
                                </Grid>
                                <Slider x:Name="MaxGrayScaleStrengthSlider"
                                        HorizontalAlignment="Stretch" VerticalAlignment="Center" IsSnapToTickEnabled="True"
                                        Minimum="0" Maximum="10"
                                        TickFrequency="1"
                                        ValueChanged="MaxGrayScaleStrengthSlider_ValueChanged"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ====================  WINDOW  ==================== -->
                <ScrollViewer x:Name="PageWindow"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14,12,14,14"
                              Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Stretch">

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="POSITION" Style="{StaticResource SectionHeader}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{x:Static prop:Lang.FrameSettings_PositionX}" Style="{StaticResource FieldLabel}"/>
                                        <ui:NumberBox x:Name="PositionX_NumberBox"
                                                      SpinButtonPlacementMode="Inline"
                                                      Value="{Binding PosX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Stretch"
                                                      ValueChanged="ChangePosition"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{x:Static prop:Lang.FrameSettings_PositionY}" Style="{StaticResource FieldLabel}"/>
                                        <ui:NumberBox x:Name="PositionY_NumberBox"
                                                      SpinButtonPlacementMode="Inline"
                                                      Value="{Binding PosY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Stretch"
                                                      ValueChanged="ChangePosition"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="SIZE" Style="{StaticResource SectionHeader}"/>
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{x:Static prop:Lang.FrameSettings_FrameWidth}" Style="{StaticResource FieldLabel}"/>
                                        <ui:NumberBox x:Name="FrameWidth_NumberBox"
                                                      SpinButtonPlacementMode="Inline"
                                                      Value="{Binding Width, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Stretch"
                                                      ValueChanged="ChangePosition"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{x:Static prop:Lang.FrameSettings_FrameHeight}" Style="{StaticResource FieldLabel}"/>
                                        <ui:NumberBox x:Name="FrameHeight_NumberBox"
                                                      SpinButtonPlacementMode="Inline"
                                                      Value="{Binding Height, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Stretch"
                                                      ValueChanged="ChangePosition"/>
                                    </StackPanel>
                                </Grid>

                                <CheckBox x:Name="SnapWidthToIconWidth_CheckBox"
                                          Checked="SnapWidthToIconWidth_CheckBox_Checked"
                                          Unchecked="SnapWidthToIconWidth_CheckBox_Checked">
                                    <TextBlock Text="{x:Static prop:Lang.FrameSettings_SnapWidthToIconWidth}" TextWrapping="Wrap"/>
                                </CheckBox>
                                <CheckBox x:Name="SnapWidthToIconWidth_PlusScrollbarWidth_CheckBox"
                                          Checked="SnapWidthToIconWidth_PlusScrollbarWidth_CheckBox_Checked"
                                          Unchecked="SnapWidthToIconWidth_PlusScrollbarWidth_CheckBox_Checked"
                                          Margin="22,4,0,0"
                                          Visibility="Collapsed">
                                    <TextBlock Text="{x:Static prop:Lang.FrameSettings_SnapWidthToIconWidth_PlusScrollbarWidth}" TextWrapping="Wrap"/>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="BEHAVIOR" Style="{StaticResource SectionHeader}"/>

                                <CheckBox x:Name="AutoExpandonCursorCheckBox"
                                          Margin="0,0,0,10"
                                          Checked="AutoExpandonCursorCheckBox_Checked"
                                          Unchecked="AutoExpandonCursorCheckBox_Unchecked">
                                    <TextBlock Text="{x:Static prop:Lang.FrameSettings_AutoExpandonCursor}" TextWrapping="Wrap"/>
                                </CheckBox>

                                <TextBlock Text="{x:Static prop:Lang.FrameSettings_ShowOnVirtualDesktopLabel}" Style="{StaticResource FieldLabel}"/>
                                <ui:TextBox x:Name="ShowOnVirtualDesktopTextBox"
                                            PlaceholderText="{x:Static prop:Lang.FrameSettings_ShowOnVirtualDesktopPlaceHolder}"
                                            HorizontalAlignment="Stretch"
                                            TextChanged="TextChangedHandler"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ====================  FOLDER  ==================== -->
                <ScrollViewer x:Name="PageFolder"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="14,12,14,14"
                              Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Stretch">

                        <Border Style="{StaticResource SettingsCard}">
                            <StackPanel>
                                <TextBlock Text="FOLDER BEHAVIOR" Style="{StaticResource SectionHeader}"/>
                                <CheckBox x:Name="FolderOpenInsideFrameCheckBox"
                                          Margin="0,0,0,8"
                                          Checked="FolderOpenInsideFrameCheckBox_Checked"
                                          Unchecked="FolderOpenInsideFrameCheckBox_Unchecked">
                                    <TextBlock Text="{x:Static prop:Lang.FrameSettings_FolderOpenInsideFrame}" TextWrapping="Wrap"/>
                                </CheckBox>
                                <CheckBox x:Name="CheckFolderSizeCheckBox"
                                          Checked="CheckFolderSizeCheckBox_Checkked"
                                          Unchecked="CheckFolderSizeCheckBox_Uncheckked">
                                    <TextBlock Text="{x:Static prop:Lang.FrameSettings_CheckFolderSize}" TextWrapping="Wrap"/>
                                </CheckBox>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#0AFFFFFF" BorderBrush="#14FFFFFF" BorderThickness="0,1,0,0" Padding="10,6,10,6">
            <ui:Button x:Name="RevertButton"
                       Content="{x:Static prop:Lang.FrameSettings_RevertButton}"
                       Icon="{ui:SymbolIcon ArrowUndo20}"
                       Height="28"
                       Padding="10,0,10,0"
                       HorizontalAlignment="Right"
                       Click="RevertButton_Click"/>
        </Border>

    </Grid>
</ui:FluentWindow>
