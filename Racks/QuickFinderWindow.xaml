<Window x:Class="Racks.QuickFinderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        Foreground="White"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        ResizeMode="NoResize"
        Title="Find in racks"
        Width="640"
        Height="440"
        Deactivated="Window_Deactivated"
        KeyDown="Window_KeyDown">
    <Border CornerRadius="14" BorderThickness="1" Margin="16"
            Background="{StaticResource RacksCardBackground}"
            BorderBrush="{StaticResource RacksCardBorder}">
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="15" Opacity="0.5"/>
        </Border.Effect>
        <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="FIND IN RACKS"
                   Foreground="{StaticResource RacksMutedForeground}" FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <Border Grid.Row="1" CornerRadius="10" Background="#18FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1">
            <TextBox x:Name="QueryBox"
                     FontSize="16"
                     Padding="10,8"
                     Background="Transparent"
                     Foreground="White"
                     CaretBrush="White"
                     BorderThickness="0"
                     VerticalContentAlignment="Center"
                     TextChanged="QueryBox_TextChanged"
                     PreviewKeyDown="QueryBox_PreviewKeyDown"/>
        </Border>

        <ListBox x:Name="Results"
                 Grid.Row="2"
                 Margin="0,8,0,0"
                 Background="Transparent"
                 BorderThickness="0"
                 Foreground="White"
                 MouseDoubleClick="Results_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                        <Image Width="20" Height="20" Source="{Binding Item.Thumbnail}" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="{Binding Item.DisplayName}" FontSize="13"/>
                            <TextBlock Text="{Binding Subtitle}" FontSize="10" Foreground="#888"/>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Row="3"
                   Text="↑↓ navigate    Enter open    Esc dismiss"
                   Foreground="#666"
                   FontSize="10"
                   Margin="0,10,0,0"/>
        </Grid>
    </Border>
</Window>
