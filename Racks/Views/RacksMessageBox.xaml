<Window x:Class="Racks.Views.RacksMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Message" Width="450" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" Foreground="White"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    
    <!-- We can use a shadow or just a simple border -->
    <Border CornerRadius="14" BorderThickness="1" Margin="20">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F0242426" Offset="0"/>
                <GradientStop Color="#E0121214" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#33FFFFFF" Offset="0"/>
                <GradientStop Color="#0AFFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <!-- Optional shadow if we have drop shadow effect, but lets keep it lightweight -->
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="15" Opacity="0.5"/>
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Custom title -->
            <TextBlock x:Name="TitleText" Text="Racks" FontSize="14" FontWeight="SemiBold" Foreground="#88FFFFFF" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <!-- Message content -->
            <TextBlock x:Name="MessageText" Grid.Row="1" Text="Message" FontSize="15" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>

            <!-- Action button -->
            <Button x:Name="OkButton" Grid.Row="2" Content="OK" Width="120" Height="36" Margin="0,20,0,0" HorizontalAlignment="Center"
                    Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF" BorderThickness="1"
                    Cursor="Hand"
                    Click="OkButton_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="18"/>
                    </Style>
                </Button.Resources>
                <!-- Add a nice hover effect to the button using WPF triggers -->
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="18">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#44FFFFFF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Border>
</Window>
