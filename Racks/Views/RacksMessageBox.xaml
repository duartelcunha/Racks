<Window x:Class="Racks.Views.RacksMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="Message" Width="450" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Background="Transparent" Foreground="White"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Shared pill-button look used by every Racks dialog for design coherence. -->
        <Style x:Key="RacksDialogButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Margin" Value="5,0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#1EFFFFFF"/>
            <Setter Property="BorderBrush" Value="#3CFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="btnScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="0.95" Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="0.95" Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleX" To="1" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="btnScale" Storyboard.TargetProperty="ScaleY" To="1" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary (confirm) variant: a subtle accent so the main action stands out. -->
        <Style x:Key="RacksDialogButtonPrimary" TargetType="Button" BasedOn="{StaticResource RacksDialogButton}">
            <Setter Property="Background" Value="#3A6FA8FF"/>
            <Setter Property="BorderBrush" Value="#66A6D2FF"/>
        </Style>
    </Window.Resources>

    <!-- Root scales+fades in on open (set from code-behind). -->
    <Border x:Name="RootBorder" CornerRadius="14" BorderThickness="1" Margin="20"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <ScaleTransform x:Name="RootScale" ScaleX="0.92" ScaleY="0.92"/>
        </Border.RenderTransform>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F0242426" Offset="0"/>
                <GradientStop Color="#E0121214" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#33FFFFFF" Offset="0"/>
                <GradientStop Color="#0AFFFFFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="4" BlurRadius="15" Opacity="0.5"/>
        </Border.Effect>
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText" Text="Racks" FontSize="13" FontWeight="SemiBold" Foreground="#88FFFFFF"
                       HorizontalAlignment="Center" Margin="0,0,0,12"/>

            <TextBlock x:Name="MessageText" Grid.Row="1" Text="Message" FontSize="15" TextWrapping="Wrap"
                       VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" LineHeight="21"/>

            <StackPanel x:Name="ButtonPanel" Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,22,0,0">
                <Button x:Name="SecondaryButton" Content="Cancel" Style="{StaticResource RacksDialogButton}"
                        Visibility="Collapsed" Click="SecondaryButton_Click"/>
                <Button x:Name="OkButton" Content="OK" Style="{StaticResource RacksDialogButtonPrimary}"
                        Click="OkButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
